<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openclaw.daily-restart</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/evon/OpenClaw/scripts/openclaw_daily_restart.sh</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>5</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>WorkingDirectory</key>
    <string>/Users/evon/OpenClaw</string>
    <key>StandardOutPath</key>
    <string>/Users/evon/OpenClaw/logs/launchd_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/evon/OpenClaw/logs/launchd_stderr.log</string>
</dict>
</plist>
